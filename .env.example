# Mapbox GL JS access token, consumed by src/components/MapView.tsx via
# import.meta.env.VITE_MAPBOX_TOKEN. Without it, the Map view renders a
# placeholder ("Map requires VITE_MAPBOX_TOKEN") rather than crashing.
#
# Local dev: copy this file to .env.local and paste your token there.
#   cp .env.example .env.local
# Production: set the same variable in the Vercel project's Environment
# Variables (Production + Preview), then redeploy.
VITE_MAPBOX_TOKEN=
